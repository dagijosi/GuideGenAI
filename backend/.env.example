# Application
PORT=3000
NODE_ENV=development

# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=qwen2.5-7b-instruct
LM_STUDIO_MAX_TOKENS=4096
LM_STUDIO_TEMPERATURE=0.3
# Per-request timeout in ms — 5 minutes handles detailed docs on local 7B models
LM_STUDIO_TIMEOUT_MS=300000

# Storage
STORAGE_PATH=./storage
SESSIONS_PATH=./storage/sessions
SCREENSHOTS_PATH=./storage/screenshots
VIDEOS_PATH=./storage/videos

# Database
DB_PATH=./storage/guidegen.sqlite

# Browser
BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# CORS
CORS_ORIGIN=http://localhost:5173
